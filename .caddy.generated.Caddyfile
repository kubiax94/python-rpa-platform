{
    local_certs
    admin off
}
localhost {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"`r`n        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    @backend path /api/* /frontend /ws
    reverse_proxy @backend 127.0.0.1:8765

    reverse_proxy 127.0.0.1:3000
}
